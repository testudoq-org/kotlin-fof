<resources>
    <style name="Theme.FOF" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#E0E0E0</item>
        <item name="colorPrimaryVariant">#BDBDBD</item>
        <item name="colorOnPrimary">#0F0F0F</item>
        <item name="colorSurface">#1A1A1A</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="android:statusBarColor">#0F0F0F</item>
        <item name="android:navigationBarColor">#0F0F0F</item>
        <item name="android:windowBackground">#0F0F0F</item>
    </style>

    <style name="Theme.FOF.Dialog" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="colorSurface">#1A1A1A</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#A0A0A0</item>
        <item name="buttonBarPositiveButtonStyle">@style/Theme.FOF.Dialog.Button</item>
    </style>

    <style name="Theme.FOF.Dialog.Button" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#E0E0E0</item>
    </style>
</resources>
