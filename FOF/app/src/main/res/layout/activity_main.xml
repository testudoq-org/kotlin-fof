<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F0F">

    <!-- App label top -->
    <TextView
        android:id="@+id/tv_app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FOFF"
        android:textColor="#888888"
        android:textSize="13sp"
        android:letterSpacing="0.25"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp" />

    <!-- Entire card is the tap target for the power menu -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_power_menu"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="#1A1A1A"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:rippleColor="#33FFFFFF"
        app:strokeColor="#383838"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/tv_app_name"
        app:layout_constraintBottom_toTopOf="@id/btn_why_foff"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.45">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="56dp"
            android:paddingBottom="56dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- Power icon -->
            <ImageView
                android:id="@+id/iv_power_icon"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_power_off"
                android:contentDescription="Open power menu"
                app:tint="#E0E0E0"
                android:layout_marginBottom="28dp" />

            <!-- Main label -->
            <TextView
                android:id="@+id/tv_power_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="POWER MENU"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:layout_marginBottom="14dp" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tv_power_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Emergency · Restart · Power Off · Lockdown"
                android:textColor="#A0A0A0"
                android:textSize="13sp"
                android:gravity="center" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- WHY FOFF? — reveals backstory on tap -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_why_foff"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="WHY FOFF?"
        android:textSize="12sp"
        android:textColor="#888888"
        android:letterSpacing="0.1"
        app:layout_constraintTop_toBottomOf="@id/card_power_menu"
        app:layout_constraintBottom_toTopOf="@id/tv_hint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom hint -->
    <TextView
        android:id="@+id/tv_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Requires Accessibility permission"
        android:textColor="#666666"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
